[node name="ContentLabel" type="Label" parent="AudioTutorSystem/TutorPanel/SubViewport/MarginContainer/VBoxContainer" unique_id=1148771841]
custom_minimum_size = Vector2(512, 517)
layout_mode = 2
size_flags_vertical = 1
theme_override_fonts/font = ExtResource("10_khr6i")
text = "Поскольку в децентрализованной сети нет «главного», узлы должны договариваться о том, какие записи считать истинными. Этот процесс называется Консенсусом. Существует два основных алгоритма:

Proof of Work (Доказательство работы): Участники (майнеры) используют вычислительную мощность оборудования для решения сложных математических задач. Тот, кто решит задачу первым, получает право записать блок.
Особенности: Высочайшая безопасность, но значительное потребление электроэнергии и низкая скорость транзакций.

Proof of Stake (Доказательство доли): Право на проверку транзакций (валидацию) получают участники, владеющие определенным количеством монет сети.
Особенности: Высокая скорость работы, энергоэффективность и масштабируемость."
autowrap_mode = 2

