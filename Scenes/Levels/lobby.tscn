theme_override_fonts/font = ExtResource("5_k87wc")
text = "Поздравляем с прохождением базового инструктажа. Блокчейн — это технология, исключающая посредников и обеспечивающая абсолютное доверие между незнакомыми людьми в цифровой среде.
Теперь вы понимаете фундамент, на котором строится интернет нового поколения. Добро пожаловать в мир прозрачных и защищенных технологий!"
autowrap_mode = 2
