[node name="ContentLabel" type="Label" parent="AudioTutorSystem/TutorPanel/SubViewport/MarginContainer/VBoxContainer" unique_id=1993713348]
custom_minimum_size = Vector2(512, 517)
layout_mode = 2
size_flags_vertical = 1
theme_override_fonts/font = ExtResource("11_b1nrc")
text = "В основе традиционных систем лежит Централизованная модель. Представьте городское управление: все решения принимаются в мэрии. Если центральный узел выходит из строя или подвергается атаке — вся инфраструктура города парализуется.

Блокчейн — это Децентрализованная сеть. Она функционирует по принципу биологического улья. Здесь нет единого контролирующего органа. Каждый компьютер в сети (узел или «нода») является равноправным участником.
Отказоустойчивость: Если один или несколько узлов отключаются, сеть продолжает работу без потери данных.
Прозрачность: Идентичная копия всей базы данных хранится одновременно у каждого участника сети."
autowrap_mode = 2

